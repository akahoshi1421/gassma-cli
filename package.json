{
  "name": "gassma-cli-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6"
  },
  "lint-staged": {
    "packages/*/src/**/*.{js,ts,jsx,tsx}": [
      "biome format --write",
      "biome lint --write"
    ]
  }
}
