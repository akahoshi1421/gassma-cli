{
  "include": ["src"],
  "compilerOptions": {
    "target": "es2016",
    "lib": ["ES2021"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "baseUrl": "./src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  }
}
